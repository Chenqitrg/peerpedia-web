{
  "$schema": "https://raw.githubusercontent.com/nicedoc/open-tauri/main/.schemas/desktop-schema.json",
  "productName": "PeerPedia",
  "version": "0.1.0",
  "identifier": "org.peerpedia.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "PeerPedia · 知诸网",
    "windows": [
      {
        "title": "PeerPedia · 知诸网",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
